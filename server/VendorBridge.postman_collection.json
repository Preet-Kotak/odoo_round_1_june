    {
      "name": "Activity Logs",
      "item": [
        {
          "name": "Get Activity Logs (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/activity-logs"
          }
        },
        {
          "name": "Get Logs - Filter by recordType",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/activity-logs?recordType=vendor",
              "query": [{ "key": "recordType", "value": "vendor" }]
