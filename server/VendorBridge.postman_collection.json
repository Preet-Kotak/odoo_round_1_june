            "url": "{{baseUrl}}/reports/dashboard"
          }
        },
        {
          "name": "Spending Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/reports/spending-summary"
